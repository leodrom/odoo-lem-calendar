<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="lem_event_calendar_entry_view_calendar" model="ir.ui.view">
        <field name="name">lem.event.calendar.entry.calendar</field>
        <field name="model">lem.event.calendar.entry</field>
        <field name="arch" type="xml">
            <lem_event_calendar string="Календар"
                      date_start="date_start"
                      date_stop="date_end"
                      color="color"
                      mode="month"
                      quick_create="false">
                <field name="status_badge" string=" " invisible="not status_badge"/>
                <field name="status" filters="1" string="Статус" invisible="True"/>
                <field name="location_id" filters="1" string="Локація"/>
                <field name="entry_type" filters="1" string="Об'єкт"/>
                <field name="entry_role" filters="1" string="Тип події" invisible="True"/>
                <field name="linked_object_name" string=" " invisible="not linked_object_name"/>
                <field name="user_id" string="Відповідальний"/>
                <field name="description" invisible="True"/>
            </lem_event_calendar>
        </field>
    </record>

    <record id="lem_event_calendar_entry_view_list" model="ir.ui.view">
        <field name="name">lem.event.calendar.entry.list</field>
        <field name="model">lem.event.calendar.entry</field>
        <field name="arch" type="xml">
            <list string="Події" default_order="date_start desc">
                <field name="name"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="location_id"/>
                <field name="user_id"/>
                <field name="linked_object_name" string="Об'єкт" optional="show"/>
                <field name="entry_type" widget="badge"
                       decoration-success="entry_type == 'event'"
                       decoration-info="entry_type == 'lead'"
                       decoration-muted="entry_type == 'manual'"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'confirmed'"
                       decoration-warning="status == 'negotiation' or status == 'waiting'"
                       decoration-danger="status == 'cancelled'"
                       decoration-info="status == 'reserve'"/>
            </list>
        </field>
    </record>

    <record id="lem_event_calendar_entry_view_form" model="ir.ui.view">
        <field name="name">lem.event.calendar.entry.form</field>
        <field name="model">lem.event.calendar.entry</field>
        <field name="arch" type="xml">
            <form string="Запис Календаря">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_linked_object"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-external-link"
                                invisible="entry_type == 'manual'">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text" invisible="entry_type != 'event'">Подія</span>
                                <span class="o_stat_text" invisible="entry_type != 'lead'">Нагода</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Entry title..."/></h1>
                    </div>
                    <group>
                        <group string="Розклад">
                            <field name="date_start"/>
                            <field name="date_end"/>
                            <field name="location_id"/>
                        </group>
                        <group string="Деталі">
                            <field name="entry_type" widget="badge" string="Тип об'єкту"/>
                            <field name="entry_role" widget="radio" class="o_role_radio" string="Тип події"/>
                            <field name="status" widget="radio" class="o_status_radio"/>
                            <field name="user_id"/>
                        </group>
                    </group>
                    <group>
                        <group string="Пов'язаний об'єкт">
                            <field name="res_model" string="Тип об'єкту"
                                   help="Оберіть тип об'єкта, з яким пов'язаний цей запис. Наприклад: Подія — для подій з модуля Events, Угода — для CRM-угод. Залиште порожнім для ручного запису."/>
                            <field name="lead_id" string="Нагода" invisible="res_model != 'crm.lead'"/>
                            <field name="res_id" string="Об'єкт" invisible="not res_model or res_model == 'crm.lead'"
                                   help="Оберіть конкретний запис обраного типу. Поле доступне після вибору типу об'єкта."/>
                        </group>
                        <group/>
                    </group>
                    <separator string="Нотатки"/>
                    <field name="description" placeholder="Нотатки..." nolabel="1"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="lem_event_calendar_entry_view_search" model="ir.ui.view">
        <field name="name">lem.event.calendar.entry.search</field>
        <field name="model">lem.event.calendar.entry</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Назва"/>
                <field name="location_id" string="Локація"/>
                <separator/>
                <filter name="confirmed"   string="Погоджено"            domain="[('status','=','confirmed')]"/>
                <filter name="negotiation" string="В процесі погодження" domain="[('status','=','negotiation')]"/>
                <filter name="reserve"     string="Резерв"               domain="[('status','=','reserve')]"/>
                <filter name="waiting"     string="Очікуємо відповідь"   domain="[('status','=','waiting')]"/>
                <filter name="cancelled"   string="Скасовано"            domain="[('status','=','cancelled')]"/>
                <separator/>
                <filter name="date_start" string="Дата початку" date="date_start"/>
                <separator/>
                <filter name="type_event"  string="Подія"                domain="[('entry_type','=','event')]"/>
                <filter name="type_lead"   string="Нагода"               domain="[('entry_type','=','lead')]"/>
                <filter name="type_manual" string="Невизначений"         domain="[('entry_type','=','manual')]"/>
                <group>
                    <filter name="group_status"   string="Статус"    context="{'group_by': 'status'}"/>
                    <filter name="group_location" string="Локація"   context="{'group_by': 'location_id'}"/>
                    <filter name="group_type"     string="Тип"       context="{'group_by': 'entry_type'}"/>
                    <filter name="group_user"     string="Відповідальний" context="{'group_by': 'user_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="lem_event_calendar_entry_action" model="ir.actions.act_window">
        <field name="name">Календар</field>
        <field name="res_model">lem.event.calendar.entry</field>
        <field name="view_mode">lem_event_calendar,list,form</field>
        <field name="path">lem-event-calendar</field>
    </record>

    <record id="lem_event_calendar_entry_action_list" model="ir.actions.act_window">
        <field name="name">Entries</field>
        <field name="res_model">lem.event.calendar.entry</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
