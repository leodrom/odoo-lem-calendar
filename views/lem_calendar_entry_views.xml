<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="lem_calendar_entry_view_calendar" model="ir.ui.view">
        <field name="name">lem.calendar.entry.calendar</field>
        <field name="model">lem.calendar.entry</field>
        <field name="arch" type="xml">
            <lem_calendar string="LEM Calendar"
                      date_start="date_start"
                      date_stop="date_end"
                      color="color"
                      mode="month"
                      quick_create="false">
                <field name="status_badge" string=" " invisible="not status_badge"/>
                <field name="status" filters="1" string="Статус" invisible="True"/>
                <field name="location_id" filters="1" string="Локація"/>
                <field name="entry_type" filters="1" string="Об'єкт"/>
                <field name="linked_object_name" string=" " invisible="not linked_object_name"/>
            </lem_calendar>
        </field>
    </record>

    <record id="lem_calendar_entry_view_list" model="ir.ui.view">
        <field name="name">lem.calendar.entry.list</field>
        <field name="model">lem.calendar.entry</field>
        <field name="arch" type="xml">
            <list string="Calendar Entries" default_order="date_start desc">
                <field name="name"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="location_id"/>
                <field name="user_id"/>
                <field name="entry_type" widget="badge"
                       decoration-success="entry_type == 'event'"
                       decoration-info="entry_type == 'lead'"
                       decoration-muted="entry_type == 'manual'"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'confirmed'"
                       decoration-warning="status == 'negotiation' or status == 'waiting'"
                       decoration-danger="status == 'cancelled'"
                       decoration-info="status == 'reserve'"/>
            </list>
        </field>
    </record>

    <record id="lem_calendar_entry_view_form" model="ir.ui.view">
        <field name="name">lem.calendar.entry.form</field>
        <field name="model">lem.calendar.entry</field>
        <field name="arch" type="xml">
            <form string="Calendar Entry">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_linked_object"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-external-link"
                                invisible="entry_type == 'manual'">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text" invisible="entry_type != 'event'">Подія</span>
                                <span class="o_stat_text" invisible="entry_type != 'lead'">Нагода</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Entry title..."/></h1>
                    </div>
                    <group>
                        <group string="Schedule">
                            <field name="date_start"/>
                            <field name="date_end"/>
                            <field name="location_id"/>
                        </group>
                        <group string="Details">
                            <field name="entry_type" widget="badge"/>
                            <field name="user_id"/>
                            <field name="status" widget="radio" class="o_status_radio"/>
                        </group>
                    </group>
                    <group>
                        <group string="Пов'язаний об'єкт">
                            <field name="res_model" string="Тип об'єкту"
                                   help="Оберіть тип об'єкта, з яким пов'язаний цей запис. Наприклад: Подія — для подій з модуля Events, Угода — для CRM-угод. Залиште порожнім для ручного запису."/>
                            <field name="res_id" string="Об'єкт" invisible="not res_model"
                                   domain="[('type', '=', 'opportunity')] if res_model == 'crm.lead' else []"
                                   help="Оберіть конкретний запис обраного типу. Поле доступне після вибору типу об'єкта."/>
                        </group>
                        <group/>
                    </group>
                    <field name="description" placeholder="Description..."/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="lem_calendar_entry_action" model="ir.actions.act_window">
        <field name="name">LEM Calendar</field>
        <field name="res_model">lem.calendar.entry</field>
        <field name="view_mode">lem_calendar,list,form</field>
    </record>

    <record id="lem_calendar_entry_action_list" model="ir.actions.act_window">
        <field name="name">Entries</field>
        <field name="res_model">lem.calendar.entry</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
