<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="lem_location_view_list" model="ir.ui.view">
        <field name="name">lem.location.list</field>
        <field name="model">lem.location</field>
        <field name="arch" type="xml">
            <list string="Locations">
                <field name="color_display" widget="html" string="Колір" readonly="1"/>
                <field name="name"/>
                <field name="entry_count" string="Entries"/>
            </list>
        </field>
    </record>

    <record id="lem_location_view_form" model="ir.ui.view">
        <field name="name">lem.location.form</field>
        <field name="model">lem.location</field>
        <field name="arch" type="xml">
            <form string="Location">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_entries"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-calendar">
                            <field name="entry_count" widget="statinfo" string="Entries"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Location name..."/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="color" widget="color_picker" string="Колір"/>
                        </group>
                    </group>
                    <field name="notes" placeholder="Notes..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="lem_location_action" model="ir.actions.act_window">
        <field name="name">Locations</field>
        <field name="res_model">lem.location</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
